<mamecheat version="1">

  <cheat desc="选择隐藏角色">
    <parameter>
      <item value="0xFF">开启</item>
      <item value="0x00">关闭</item>
    </parameter>
    <script state="run">
      <action>maincpu.pb@10A6A7=param</action>
    </script>
  </cheat>

  <cheat desc="总有 10000 分奖励">
    <script state="run">
      <action>maincpu.pb@109CB8=24</action>
    </script>
  </cheat>

  <cheat desc="查看游戏难度段位">
    <script state="run">
      <output format="难度段位 : %d">
        <argument>maincpu.pb@(10C9D3)</argument>
      </output>
    </script>
  </cheat>

  <cheat desc="始终保持最低难度段位">
    <script state="run">
      <action>maincpu.pd@10C9D2=00F00000</action>
    </script>
  </cheat>

  <cheat desc="选择游戏模式">
    <comment>请在进入选择玩家画面前启用.</comment>
    <parameter>
      <item value="0x04">扩展模式</item>
      <item value="0x02">高难度模式</item>
      <item value="0x00">关卡编辑模式</item>
      <item value="0x06">特殊模式</item>
    </parameter>
    <script state="on">
      <action>temp0=maincpu.pb@10CA0F</action>
    </script>
    <script state="run">
      <action condition="(maincpu.pb@10A6B0 == 00)">maincpu.pb@10A6B0=param</action>
      <action condition="(param == 00) OR (param == 06)">maincpu.pb@10CA0F=FF</action>
    </script>
    <script state="off">
      <action>maincpu.pb@10CA0F=temp0</action>
    </script>
  </cheat>

